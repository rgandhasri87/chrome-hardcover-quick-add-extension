{
    "manifest_version" : 3,
    "name" : "Hardcover Quick Add",
    "version" : "1.0",
    "description" : "Add books to Hardcover from anywhere!",

    "permissions" : [
        "contextMenus",
        "sidePanel"
    ],

    "background" : {
        "service_worker" : "background.js"
    },

    "side_panel" : {
        "default_path" : "sidepanel.html"
    }
}